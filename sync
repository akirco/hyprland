#!/bin/bash

# 配置同步脚本
# 将 ~/.config 同步到仓库 .config（只同步仓库已有的目录/文件）

DRY_RUN=false
VERBOSE=false
FORCE=false
SOURCE_ARG=""
TARGET_ARG=""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $1"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; }
log_dryrun() { echo -e "${CYAN}[DRY-RUN]${NC} $1"; }

CONFIG_EXTENSIONS=(
    "*.conf" "*.toml" "*.ini" "*.json" "*.yaml" "*.yml"
    "*.sh" "*.env" "*.rc" "*.txt" "*.cfg"
    "*.zsh" "*.fish" "*.bash"
)

show_help() {
    echo "配置同步脚本 - 将 ~/.config 同步到仓库 .config"
    echo
    echo "用法: $0 [选项] [源目录] [目标目录]"
    echo
    echo "选项:"
    echo "  -d, --dry-run    预览模式，不实际执行"
    echo "  -v, --verbose    显示详细过程"
    echo "  -f, --force      强制覆盖，不询问"
    echo "  -h, --help       显示帮助"
    echo
    echo "参数:"
    echo "  源目录    现有配置目录 (默认: ~/.config)"
    echo "  目标目录  仓库配置目录 (默认: ./.config)"
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
        -d | --dry-run) DRY_RUN=true; shift ;;
        -v | --verbose) VERBOSE=true; shift ;;
        -f | --force) FORCE=true; shift ;;
        -h | --help) show_help; exit 0 ;;
        -*) log_error "未知选项: $1"; exit 1 ;;
        *)
            if [ -z "$SOURCE_ARG" ]; then SOURCE_ARG="$1"
            elif [ -z "$TARGET_ARG" ]; then TARGET_ARG="$1"; fi
            shift
            ;;
        esac
    done
}

get_source_dir() { echo "${SOURCE_ARG:-$HOME/.config}"; }
get_target_dir() { echo "${TARGET_ARG:-$PWD/.config}"; }

check_dirs() {
    local SOURCE_DIR=$(get_source_dir)
    local TARGET_DIR=$(get_target_dir)
    [ ! -d "$SOURCE_DIR" ] && log_error "源目录不存在: $SOURCE_DIR" && exit 1
    [ ! -d "$TARGET_DIR" ] && log_error "目标目录不存在: $TARGET_DIR" && exit 1
    log_info "源: $SOURCE_DIR -> 目标: $TARGET_DIR"
}

do_replace() {
    local tgt_file="$1"
    local src_file="$2"
    local rel_path="$3"

    local backup="$tgt_file.bak.$(date +%Y%m%d_%H%M%S)"
    cp "$tgt_file" "$backup"
    log_success "备份: $rel_path -> $backup"

    mkdir -p "$(dirname "$tgt_file")"
    cp "$src_file" "$tgt_file"
    log_success "已覆盖: $rel_path"
    return 0
}

deploy() {
    local SOURCE_DIR=$(get_source_dir)
    local TARGET_DIR=$(get_target_dir)
    local changed=0
    local skipped=0
    local identical=0

    local find_args=()
    for ext in "${CONFIG_EXTENSIONS[@]}"; do
        find_args+=("-name" "$ext" "-o")
    done
    find_args=("${find_args[@]:0:${#find_args[@]}-1}")

    # 遍历仓库目标目录中的文件
    while IFS= read -r -d '' tgt_file; do
        local rel_path="${tgt_file#$TARGET_DIR/}"
        local src_file="$SOURCE_DIR/$rel_path"

        if [ ! -f "$src_file" ]; then
            [ "$VERBOSE" = true ] && log_warning "源文件不存在: $rel_path"
            continue
        fi

        if diff -q "$src_file" "$tgt_file" >/dev/null 2>&1; then
            [ "$VERBOSE" = true ] && log_info "相同: $rel_path"
            ((identical++))
            continue
        fi

        log_info "差异: $rel_path"

        if [ "$DRY_RUN" = true ]; then
            log_dryrun "将覆盖: $rel_path"
        elif [ "$FORCE" = true ]; then
            do_replace "$tgt_file" "$src_file" "$rel_path" && ((changed++)) || ((skipped++))
        else
            read -p "覆盖? [y/N/q]: " -n 1 -r
            echo
            case "$REPLY" in
            [Yy]) do_replace "$tgt_file" "$src_file" "$rel_path" && ((changed++)) || ((skipped++)) ;;
            [Qq]) log_info "取消"; break ;;
            *) ((skipped++)) ;;
            esac
        fi
    done < <(find "$TARGET_DIR" -type f \( "${find_args[@]}" \) -print0 2>/dev/null)

    echo
    log_info "完成: 覆盖=$changed 跳过=$skipped 相同=$identical"
    [ "$DRY_RUN" = true ] && log_info "预览模式，未实际执行"
}

main() {
    parse_args "$@"
    check_dirs
    [ "$DRY_RUN" = true ] && log_info "=== 预览模式 ==="
    deploy
    log_success "完成"
}

main "$@"