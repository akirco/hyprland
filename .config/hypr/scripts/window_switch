#!/usr/bin/env bash

# MODE selection: switch (default) or move
MODE="${1:-switch}"
# Minimize workspace name (change to your actual workspace name)
MINIMIZE_WORKSPACE="min"
# Get current workspace name
CURRENT_WORKSPACE=$(hyprctl activeworkspace -j | jq -r '.name')

TEMP_WINDOWS="/tmp/hypr_windows_$$.txt"
TEMP_DISPLAY="/tmp/hypr_display_$$.txt"
TEMP_ADDR_MAP="/tmp/hypr_addr_map_$$.txt"

cleanup() {
  rm -f "$TEMP_WINDOWS" "$TEMP_DISPLAY" "$TEMP_ADDR_MAP"
}
trap cleanup EXIT

# Show help information
show_help() {
  echo "Usage: $0 [mode]"
  echo "Modes:"
  echo "  switch - window switch mode (default)"
  echo "  move   - move windows from minimized workspace to current workspace"
  echo ""
  echo "Minimize workspace name: $MINIMIZE_WORKSPACE"
  echo "Current workspace: $CURRENT_WORKSPACE"
  exit 0
}

# Check mode parameter
if [ "$MODE" = "--help" ] || [ "$MODE" = "-h" ]; then
  show_help
elif [ "$MODE" != "switch" ] && [ "$MODE" != "move" ]; then
  echo "Error: invalid mode '$MODE', use 'switch' or 'move'"
  echo "Use $0 --help for help"
  exit 1
fi

# Get current focused window address
get_active_window_address() {
  hyprctl activewindow -j 2>/dev/null | jq -r '.address // empty'
}

simplify_class() {
  local class="$1"

  # Remove common app identifier suffixes
  case "$class" in
  # Edge/Chrome PWA apps
  *msedge-*-Default*)
    echo "msedge"
    ;;
  *chrome-*-Default*)
    echo "chrome"
    ;;
  # Firefox related
  *firefox-*)
    echo "firefox"
    ;;
  firefox*)
    echo "firefox"
    ;;
  kitty-*)
    echo "kitty"
    ;;
  alacritty-*)
    echo "alacritty"
    ;;
  jetbrains-*)
    echo "$class" | sed -E 's/jetbrains-([a-zA-Z]+)-.*/\1/'
    ;;
  # Generic: remove UUID/hash suffixes
  *)
    # Remove common suffix patterns
    simplified=$(echo "$class" | sed -E '
                # Remove browser extension ID pattern (32 char alphanumeric)
                s/-[a-f0-9]{32}-Default$//
                s/-[a-f0-9]{32}$//
                # Remove common version number patterns
                s/-[0-9]+\.[0-9]+\.[0-9]+$//
                s/-[0-9]+$//
                # Remove process ID pattern
                s/-[0-9]{4,5}$//
                # Remove timestamp or random string
                s/-[a-f0-9]{8,}$//
                # Remove "instance" suffix
                s/-instance[0-9]*$//
                # If there are multiple dash-separated parts, keep only the first
                s/^([^-]+)-.*/\1/
            ')

    # If not simplified, return original class
    if [ -z "$simplified" ] || [ "$simplified" = "$class" ]; then
      echo "$class"
    else
      echo "$simplified"
    fi
    ;;
  esac
}

# Capitalize first letter function
capitalize_first() {
  local str="$1"
  echo "${str^}"
}

# Get all window info
get_all_windows() {
  if [ "$MODE" = "move" ]; then
    # move mode: only show minimized workspace windows
    hyprctl clients -j | jq -r --arg ws "special:$MINIMIZE_WORKSPACE" \
      '.[] | select(.workspace.name == $ws) | "\(.address)|\(.class)|\(.title)|\(.workspace.name)"' 2>/dev/null
  else
    # switch mode: show all windows
    hyprctl clients -j | jq -r '.[] | "\(.address)|\(.class)|\(.title)|\(.workspace.name)"' 2>/dev/null
  fi
}

get_windows() {
  local active_addr=""

  # Only switch mode needs to get current active window
  if [ "$MODE" = "switch" ]; then
    active_addr=$(get_active_window_address)
  fi

  # Clear temp files
  >"$TEMP_WINDOWS"
  >"$TEMP_DISPLAY"
  >"$TEMP_ADDR_MAP"

  # Get window info
  get_all_windows >"$TEMP_WINDOWS"

  # If no windows found, exit
  if [ ! -s "$TEMP_WINDOWS" ]; then
    if [ "$MODE" = "move" ]; then
      notify-send "Window Manager" "No windows in minimized workspace '$MINIMIZE_WORKSPACE'"
    else
      notify-send "Window Switcher" "No windows found"
    fi
    exit 0
  fi

  local active_window_found=false

  # switch mode: process current focused window first, put it at the top
  if [ "$MODE" = "switch" ] && [ -n "$active_addr" ] && grep -q "^$active_addr|" "$TEMP_WINDOWS"; then
    active_window_found=true
    active_line=$(grep "^$active_addr|" "$TEMP_WINDOWS")

    if [ -n "$active_line" ]; then
      IFS='|' read -r addr class title workspace <<<"$active_line"
      simple_class=$(simplify_class "$class")
      capitalized_class=$(capitalize_first "$simple_class")

      if [ ${#title} -gt 70 ]; then
        title="${title:0:67}..."
      fi

      # Add arrow marker to indicate current focused window
      echo "❯ [$workspace] $capitalized_class - $title" >>"$TEMP_DISPLAY"
      echo "$addr" >>"$TEMP_ADDR_MAP"

      # Remove processed current focused window from TEMP_WINDOWS
      grep -v "^$active_addr|" "$TEMP_WINDOWS" >"${TEMP_WINDOWS}.tmp"
      mv "${TEMP_WINDOWS}.tmp" "$TEMP_WINDOWS"
    fi
  fi

  # Process other windows
  while IFS='|' read -r addr class title workspace; do
    simple_class=$(simplify_class "$class")
    capitalized_class=$(capitalize_first "$simple_class")

    if [ ${#title} -gt 70 ]; then
      title="${title:0:67}..."
    fi

    # move mode: show different prefix
    if [ "$MODE" = "move" ]; then
      echo "↗ [$workspace] $capitalized_class - $title" >>"$TEMP_DISPLAY"
    elif [ "$active_window_found" = true ] && [ "$addr" = "$active_addr" ]; then
      continue # already processed current window, skip
    else
      echo "    [$workspace] $capitalized_class - $title" >>"$TEMP_DISPLAY"
    fi

    echo "$addr" >>"$TEMP_ADDR_MAP"
  done <"$TEMP_WINDOWS"
}

# Show wofi menu
show_menu() {
  local prompt_text=""

  if [ "$MODE" = "move" ]; then
    prompt_text="Restore from '$MINIMIZE_WORKSPACE' → $CURRENT_WORKSPACE"
  else
    prompt_text="Switch window"
  fi

  cat "$TEMP_DISPLAY" | wofi \
    --prompt "$prompt_text: " \
    --insensitive \
    --allow-markup \
    --width 1024 \
    --height 350 \
    --location center \
    --hide-scroll \
    --cache-file /dev/null \
    --matching fuzzy \
    --normal-window \
    --dmenu
}

# Focus window function
focus_window() {
  local addr="$1"

  # Ensure address format is correct
  if [[ ! "$addr" =~ ^0x ]]; then
    addr="0x$addr"
  fi

  # Focus window
  hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1
  return $?
}

# Move window to current workspace and focus
move_window_to_current() {
  local addr="$1"

  # Ensure address format is correct
  if [[ ! "$addr" =~ ^0x ]]; then
    addr="0x$addr"
  fi

  echo "Moving window $addr from '$MINIMIZE_WORKSPACE' to '$CURRENT_WORKSPACE'..." >>/tmp/hypr_move_debug.log

  # Move window to current workspace
  hyprctl dispatch movetoworkspace "$CURRENT_WORKSPACE,address:$addr" >/dev/null 2>&1

  # Wait a bit for window move to complete
  sleep 0.1

  # Focus window
  hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1

  return $?
}

# Main function
main() {
  get_windows

  if [ ! -s "$TEMP_DISPLAY" ]; then
    exit 0
  fi

  selected=$(show_menu)

  if [ -n "$selected" ]; then
    # Use line number to match directly
    line_num=0
    while read -r line; do
      ((line_num++))
      # Remove possible whitespace before comparing
      clean_line=$(echo "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
      clean_selected=$(echo "$selected" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')

      if [ "$clean_line" = "$clean_selected" ]; then
        # Get address corresponding to line number
        selected_addr=$(sed -n "${line_num}p" "$TEMP_ADDR_MAP" | tr -d '\n')

        if [ -n "$selected_addr" ]; then
          if [ "$MODE" = "move" ]; then
            # move mode: move window to current workspace and focus
            move_window_to_current "$selected_addr"

            if [ $? -eq 0 ]; then
              notify-send "Window Manager" "Restored window to workspace '$CURRENT_WORKSPACE'"
            else
              notify-send "Window Manager" "Failed to restore window" -u critical
            fi
          else
            # switch mode: directly focus window
            focus_window "$selected_addr"
          fi
        fi
        break
      fi
    done <"$TEMP_DISPLAY"
  fi
}

main
