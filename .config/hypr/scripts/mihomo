#!/usr/bin/env bash

CONFIG_DIR="$HOME/.config/mihomo"
MIHOMO_CMD="mihomo"
LOG_FILE="$CONFIG_DIR/mihomo.log"
PID_FILE="/tmp/mihomo.pid"
SERVE_PID_FILE="/tmp/mihomo-ui.pid"
SERVE_PORT=1235
SERVE_DIR="$HOME/.config/mihomo/ui"

API_URL="http://127.0.0.1:9090"
SECRET="你的SECRET"
GROUP_NAME="🚀 手动切换"
TEST_URL="http://www.gstatic.com/generate_204"
TIMEOUT=2000

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

check_mihomo() {
    if ! command -v $MIHOMO_CMD &> /dev/null; then
        echo -e "${RED}错误: 未找到 $MIHOMO_CMD 命令${NC}"
        echo "请确保已安装 mihomo"
        exit 1
    fi
}

check_config() {
    if [ ! -d "$CONFIG_DIR" ]; then
        echo -e "${YELLOW}警告: 配置目录 $CONFIG_DIR 不存在${NC}"
        echo "将使用默认配置"
    fi
}

start_mihomo() {
    check_mihomo
    check_config

    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p $PID > /dev/null 2>&1; then
            echo -e "${YELLOW}Mihomo 已经在运行 (PID: $PID)${NC}"
            return 0
        else
            echo -e "${YELLOW}发现旧的 PID 文件，正在清理...${NC}"
            rm -f "$PID_FILE"
        fi
    fi

    echo -e "${BLUE}正在启动 Mihomo...${NC}"

    $MIHOMO_CMD -d "$CONFIG_DIR" >> "$LOG_FILE" 2>&1 &

    PID=$!
    echo $PID > "$PID_FILE"

    sleep 2

    if ps -p $PID > /dev/null 2>&1; then
        echo -e "${GREEN}✓ Mihomo 启动成功 (PID: $PID)${NC}"
        echo "日志文件: $LOG_FILE"
        echo "PID 文件: $PID_FILE"
    else
        echo -e "${RED}✗ Mihomo 启动失败${NC}"
        echo "请检查日志: $LOG_FILE"
        rm -f "$PID_FILE"
        return 1
    fi
}

stop_mihomo() {
    if [ ! -f "$PID_FILE" ]; then
        echo -e "${YELLOW}Mihomo 未运行${NC}"
        return 0
    fi

    PID=$(cat "$PID_FILE")

    if ps -p $PID > /dev/null 2>&1; then
        echo -e "${BLUE}正在停止 Mihomo (PID: $PID)...${NC}"
        kill $PID

        for i in {1..10}; do
            if ! ps -p $PID > /dev/null 2>&1; then
                break
            fi
            sleep 1
        done

        if ps -p $PID > /dev/null 2>&1; then
            echo -e "${YELLOW}强制停止 Mihomo...${NC}"
            kill -9 $PID
        fi
    fi

    rm -f "$PID_FILE"
    echo -e "${GREEN}✓ Mihomo 已停止${NC}"
}

restart_mihomo() {
    echo -e "${BLUE}正在重启 Mihomo...${NC}"
    stop_mihomo
    sleep 2
    start_mihomo
}

status_mihomo() {
    if [ -f "$PID_FILE" ]; then
        PID=$(cat "$PID_FILE")
        if ps -p $PID > /dev/null 2>&1; then
            echo -e "${GREEN}✓ Mihomo 正在运行 (PID: $PID)${NC}"
            return 0
        else
            echo -e "${YELLOW}⚠ Mihomo 进程异常 (PID: $PID 不存在)${NC}"
            return 1
        fi
    else
        echo -e "${YELLOW}Mihomo 未运行${NC}"
        return 2
    fi
}

show_log() {
    if [ -f "$LOG_FILE" ]; then
        echo -e "${BLUE}=== Mihomo 日志 (最后 20 行) ===${NC}"
        tail -n 20 "$LOG_FILE"
    else
        echo -e "${YELLOW}日志文件不存在${NC}"
    fi
}

test_and_switch() {
    local encoded_group=$(printf "%s" "$GROUP_NAME" | jq -sRr @uri)
    local proxies_json=$(curl -s -H "Authorization: Bearer $SECRET" "$API_URL/proxies/$encoded_group")
    mapfile -t proxies < <(echo "$proxies_json" | jq -r '.all[] | select(. != "DIRECT" and . != "REJECT" and . != "GLOBAL")')
    local total_nodes=${#proxies[@]}

    if [ "$total_nodes" -eq 0 ]; then
        notify-send -u critical "❌ 测速失败" "未在[$GROUP_NAME] 中找到有效节点"
        exit 1
    fi

    local NOTIFY_ID=$(notify-send -p -i network-wireless "Mihomo 测速开始" "共发现 $total_nodes 个节点，准备测速...")
    local min_delay=9999
    local best_proxy=""
    local current_index=0

    for name in "${proxies[@]}"; do
        ((current_index++))
        local percent=$(( current_index * 100 / total_nodes ))
        local encoded_name=$(printf "%s" "$name" | jq -sRr @uri)

        local delay_json=$(curl -s -G "$API_URL/proxies/$encoded_name/delay" \
            -H "Authorization: Bearer $SECRET" \
            --data-urlencode "url=$TEST_URL" \
            --data-urlencode "timeout=$TIMEOUT")

        local delay=$(echo "$delay_json" | jq -r '.delay // 9999')

        if [ "$delay" -eq 9999 ]; then
            status_text="❌ 超时"
        else
            status_text="⚡ ${delay}ms"
            if [ "$delay" -lt "$min_delay" ]; then
                min_delay=$delay
                best_proxy=$name
            fi
        fi

        echo -e "${BLUE}[$current_index/$total_nodes]${NC} $name -> $status_text"

        local notify_body="当前测试: $name ($status_text)\n🏆 暂定最优: ${best_proxy:-无} (${min_delay}ms)"
        notify-send -r "$NOTIFY_ID" -h int:value:"$percent" -i network-transmit-receive "测速进度 ($current_index/$total_nodes)" "$notify_body"
    done

    if [ -n "$best_proxy" ]; then
        curl -s -X PUT "$API_URL/proxies/$encoded_group" \
            -H "Authorization: Bearer $SECRET" \
            -H "Content-Type: application/json" \
            -d "{\"name\": \"$best_proxy\"}"

        notify-send -r "$NOTIFY_ID" -i software-update-available "✅[$GROUP_NAME] 切换完成" "🏆 最优节点: $best_proxy\n⚡ 延迟: ${min_delay}ms"
        echo -e "${GREEN}✓ 已切换至最优节点: $best_proxy (${min_delay}ms)${NC}"
    else
        notify-send -r "$NOTIFY_ID" -u critical "❌ 测速失败" "所有节点均超时，未进行切换"
        echo -e "${RED}✗ 所有节点测试超时${NC}"
    fi
}

show_help() {
    echo "Mihomo Service Management Script"
    echo ""
    echo "Usage: $0 [option]"
    echo ""
    echo "Options:"
    echo "  start    Start Mihomo"
    echo "  stop     Stop Mihomo"
    echo "  restart  Restart Mihomo"
    echo "  status   Check status"
    echo "  log      View logs"
    echo "  switch   Speed test and switch to best node"
    echo "  ui       Start/Stop Mihomo Web UI (miniserve)"
    echo "  help     Show this help message"
    echo ""
    echo "Config directory: $CONFIG_DIR"
}

serve() {
    if [ -f "$SERVE_PID_FILE" ] && kill -0 $(cat "$SERVE_PID_FILE") 2>/dev/null; then
        PID=$(cat "$SERVE_PID_FILE")
        kill $PID
        rm -f "$SERVE_PID_FILE"
        echo "Mihomo UI 已停止 (PID: $PID)"
        hyprctl notify -1 3000 "0xff0000" "Mihomo UI 已停止" "端口: $SERVE_PORT"
    else
        if [ ! -d "$SERVE_DIR" ]; then
            echo -e "${RED}错误: 目录不存在: $SERVE_DIR${NC}"
            hyprctl notify -1 5000 "0xff0000" "错误" "目录不存在: $SERVE_DIR"
            exit 1
        fi
        
        miniserve "$SERVE_DIR" --index "index.html" -p $SERVE_PORT &
        echo $! > "$SERVE_PID_FILE"
        
        sleep 1
        
        echo "Mihomo UI 已启动 (PID: $!, 端口: $SERVE_PORT)"
        hyprctl notify -1 3000 "0x00ff00" "Mihomo UI 已启动" "端口: $SERVE_PORT\n本地: http://localhost:$SERVE_PORT"
        
        yad --html --browser --uri="http://127.0.0.1:$SERVE_PORT" --name=mihomoui
    fi
}

ui() {
    serve
}

main() {
    case "$1" in
        start)
            start_mihomo
            ;;
        stop)
            stop_mihomo
            ;;
        restart)
            restart_mihomo
            ;;
        status)
            status_mihomo
            ;;
        log)
            show_log
            ;;
        switch)
            test_and_switch
            ;;
        serve)
            serve
            ;;
        ui)
            ui
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            if [ -z "$1" ]; then
                start_mihomo
            else
                echo -e "${RED}未知选项: $1${NC}"
                show_help
                exit 1
            fi
            ;;
    esac
}

main "$@"